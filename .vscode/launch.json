{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Next.js",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "port": 9229,
            "restart": true,
            "console": "integratedTerminal",
            "protocol": "inspector",
            "env": {
                "NODE_OPTIONS": "--inspect"
            }
        }
    ]
}